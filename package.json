{
  "name": "fantastic-system",
  "version": "0.0.0",
  "description": "enhance your VRChat life",
  "keywords": [
    "vrchat"
  ],
  "homepage": "https://github.com/pypy-vrc/fantastic-system#readme",
  "bugs": {
    "url": "https://github.com/pypy-vrc/fantastic-system/issues"
  },
  "license": "MIT",
  "author": "pypy <git@pypy.moe>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pypy-vrc/fantastic-system.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f",
    "postinstall": "electron-builder install-app-deps && electron-rebuild -f",
    "pack": "electron-builder --x64 --dir",
    "dist": "electron-builder --x64",
    "dev": "npm run dev:main && npm run dev:preload && npm run dev:renderer",
    "prod": "npm run prod:main && npm run prod:preload && npm run prod:renderer",
    "dev:main": "webpack --config webpack.main.config.js --mode development",
    "watch:main": "webpack --config webpack.main.config.js --mode development --watch",
    "prod:main": "webpack --config webpack.main.config.js --mode production",
    "dev:preload": "webpack --config webpack.preload.config.js --mode development",
    "watch:preload": "webpack --config webpack.preload.config.js --mode development --watch",
    "prod:preload": "webpack --config webpack.preload.config.js --mode production",
    "dev:renderer": "webpack --config webpack.renderer.config.js --mode development",
    "watch:renderer": "webpack --config webpack.renderer.config.js --mode development --watch",
    "prod:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "lint": "eslint --ext .js,.jsx,.ts src/ && prettier --check src/"
  },
  "dependencies": {
    "better-sqlite3": "^7.4.3",
    "native": "file:native"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^5.15.4",
    "@intlify/vue-i18n-loader": "^2.1.2",
    "@types/better-sqlite3": "^5.4.3",
    "@types/node": "^16.4.13",
    "@typescript-eslint/eslint-plugin": "^4.29.0",
    "@typescript-eslint/parser": "^4.29.0",
    "@vscode/codicons": "^0.0.21",
    "@vue/compiler-sfc": "^3.1.5",
    "copy-webpack-plugin": "^9.0.1",
    "css-loader": "^6.2.0",
    "electron": "^13.1.8",
    "electron-builder": "^22.11.7",
    "electron-rebuild": "^2.3.5",
    "element-plus": "^1.0.2-beta.70",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "famfamfam-flags": "^1.0.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.3.2",
    "mini-css-extract-plugin": "^2.2.0",
    "nano-equal": "^2.0.2",
    "node-addon-api": "*",
    "node-loader": "^2.0.0",
    "noty": "^3.2.0-beta-deprecated",
    "prettier": "^2.3.2",
    "pug": "^3.0.2",
    "pug-plain-loader": "^1.1.0",
    "raw-loader": "^4.0.2",
    "sass": "^1.37.5",
    "sass-loader": "^12.1.0",
    "terser-webpack-plugin": "^5.1.4",
    "ts-loader": "^9.2.5",
    "typescript": "^4.3.5",
    "url-loader": "^4.1.1",
    "validator": "^13.6.0",
    "vue": "^3.1.5",
    "vue-i18n": "^9.1.7",
    "vue-loader": "^16.5.0",
    "vue-router": "^4.0.10",
    "vue3-lazyload": "*",
    "webpack": "^5.49.0",
    "webpack-cli": "^4.7.2"
  },
  "engines": {
    "node": ">= 14.17.0"
  }
}
